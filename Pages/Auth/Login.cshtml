@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="login-page">
    <div class="login-orb orb-primary" aria-hidden="true"></div>
    <div class="login-orb orb-secondary" aria-hidden="true"></div>

    <div class="login-card">
        <div class="login-card-header">
            <span class="login-badge">PennyWise</span>
            <h1>Welcome to PennyWise</h1>
            <p>Sign in to continue managing your money.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert alert-success" role="alert">@Model.Message</div>
        }

        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn login-btn w-100">Sign in</button>
            <a asp-page="/Auth/Signup" class="btn signup-btn w-100 mt-2">Sign up</a>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
