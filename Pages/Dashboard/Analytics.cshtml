@page
@{
    ViewData["Title"] = "Analytics";
}

<section class="dashboard">
    <div class="dashboard__header">
        <div>
            <span class="dashboard__eyebrow">Trend Analysis</span>
            <h1>Analytics</h1>
            <p>Review monthly financial performance, savings behavior, and category-level patterns.</p>
        </div>
        <div class="dashboard__action">6-month window</div>
    </div>

    <div class="stats-grid">
        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__label">Income Trend</span>
                <span class="metric-card__trend metric-card__trend--good">+8.7%</span>
            </div>
            <div class="metric-card__value">$5,000</div>
            <div class="metric-card__label">vs last month: $4,600</div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__label">Expense Trend</span>
                <span class="metric-card__trend metric-card__trend--bad">+16.1%</span>
            </div>
            <div class="metric-card__value">$3,600</div>
            <div class="metric-card__label">vs last month: $3,100</div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__label">Savings Rate</span>
                <span class="metric-card__trend metric-card__trend--good">28.0%</span>
            </div>
            <div class="metric-card__value">28.0%</div>
            <div class="metric-card__label">Of your total income</div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__label">Best Month</span>
                <span class="metric-card__trend metric-card__trend--good">June</span>
            </div>
            <div class="metric-card__value">$1,520</div>
            <div class="metric-card__label">Highest projected savings</div>
        </article>
    </div>

    <div class="analytics-grid">
        <section class="panel">
            <div class="panel__header">
                <div>
                    <h2>6-Month Financial Trend</h2>
                    <p>Income, expenses, and savings moving together over time.</p>
                </div>
            </div>

            <svg class="line-chart" viewBox="0 0 920 360" role="img" aria-label="Six-month financial trend">
                <rect x="0" y="0" width="920" height="360" fill="#fff" />
                <g stroke="#e7eaf2" stroke-width="1">
                    <line x1="70" y1="40" x2="880" y2="40" />
                    <line x1="70" y1="100" x2="880" y2="100" />
                    <line x1="70" y1="160" x2="880" y2="160" />
                    <line x1="70" y1="220" x2="880" y2="220" />
                    <line x1="70" y1="280" x2="880" y2="280" />
                    <line x1="70" y1="320" x2="880" y2="320" />
                </g>
                <g stroke="#dfe3ee" stroke-width="1">
                    <line x1="70" y1="40" x2="70" y2="320" />
                    <line x1="232" y1="40" x2="232" y2="320" />
                    <line x1="394" y1="40" x2="394" y2="320" />
                    <line x1="556" y1="40" x2="556" y2="320" />
                    <line x1="718" y1="40" x2="718" y2="320" />
                    <line x1="880" y1="40" x2="880" y2="320" />
                </g>

                <polyline fill="none" stroke="#14b8a6" stroke-width="3.5" points="70,176 232,162 394,170 556,146 718,154 880,136" />
                <polyline fill="none" stroke="#4f46e5" stroke-width="3.5" points="70,186 232,176 394,182 556,156 718,160 880,142" />
                <polyline fill="none" stroke="#9aa8f5" stroke-width="3.5" points="70,232 232,224 394,228 556,198 718,206 880,184" />

                <g fill="#14b8a6">
                    <circle cx="556" cy="146" r="5" />
                </g>
                <g fill="#8ea0f4">
                    <circle cx="70" cy="176" r="5" />
                    <circle cx="232" cy="162" r="5" />
                    <circle cx="394" cy="170" r="5" />
                    <circle cx="718" cy="154" r="5" />
                    <circle cx="880" cy="136" r="5" />
                </g>
                <rect x="720" y="150" width="140" height="94" rx="14" fill="#fff" stroke="#dde2ef" />
                <text x="740" y="178" fill="#1b2b48" font-size="18" font-family="Nunito, Segoe UI, sans-serif">Apr</text>
                <text x="740" y="204" fill="#14b8a6" font-size="16" font-family="Nunito, Segoe UI, sans-serif">Income : 4800</text>
                <text x="740" y="232" fill="#4f46e5" font-size="16" font-family="Nunito, Segoe UI, sans-serif">Expenses : 3400</text>
                <text x="740" y="260" fill="#9aa8f5" font-size="16" font-family="Nunito, Segoe UI, sans-serif">Savings : 1400</text>

                <g fill="#8b96ad" font-size="14" font-family="Nunito, Segoe UI, sans-serif">
                    <text x="60" y="325">0</text>
                    <text x="42" y="285">1500</text>
                    <text x="42" y="225">3000</text>
                    <text x="42" y="165">4500</text>
                    <text x="42" y="45">6000</text>
                    <text x="60" y="345">Jan</text>
                    <text x="222" y="345">Feb</text>
                    <text x="384" y="345">Mar</text>
                    <text x="546" y="345">Apr</text>
                    <text x="708" y="345">May</text>
                    <text x="870" y="345">Jun</text>
                </g>
            </svg>
        </section>

        <section class="panel">
            <div class="panel__header">
                <div>
                    <h2>Savings Breakdown</h2>
                    <p>How each month contributes to retained cash.</p>
                </div>
            </div>
            <div class="donut-meta">
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#14b8a6;"></span>
                    <span>January</span>
                    <strong>$1,050</strong>
                </div>
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#4f46e5;"></span>
                    <span>February</span>
                    <strong>$1,120</strong>
                </div>
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#9aa8f5;"></span>
                    <span>March</span>
                    <strong>$980</strong>
                </div>
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#f4a300;"></span>
                    <span>April</span>
                    <strong>$1,400</strong>
                </div>
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#ea4c89;"></span>
                    <span>May</span>
                    <strong>$1,260</strong>
                </div>
                <div class="donut-row">
                    <span class="donut-row__swatch" style="background:#00a65a;"></span>
                    <span>June</span>
                    <strong>$1,520</strong>
                </div>
            </div>
        </section>
    </div>
</section>
