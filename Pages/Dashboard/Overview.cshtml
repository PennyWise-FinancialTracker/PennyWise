@page
@{
    ViewData["Title"] = "Overview";
}

<section class="dashboard">
    <div class="dashboard__header">
        <div>
            <span class="dashboard__eyebrow">Financial Snapshot</span>
            <h1>Overview Dashboard</h1>
            <p>Track income, expenses, savings, and recent activity from one high-level workspace.</p>
        </div>
        <div class="dashboard__action">Updated March 12, 2026</div>
    </div>

    <div class="stats-grid">
        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__icon metric-card__icon--income">+</span>
                <span class="metric-card__trend metric-card__trend--good">+12%</span>
            </div>
            <div>
                <div class="metric-card__label">Total Income</div>
                <div class="metric-card__value">$5,000</div>
            </div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__icon metric-card__icon--expense">-</span>
                <span class="metric-card__trend metric-card__trend--bad">+8%</span>
            </div>
            <div>
                <div class="metric-card__label">Total Expenses</div>
                <div class="metric-card__value">$3,600</div>
            </div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__icon metric-card__icon--balance">=</span>
                <span class="metric-card__trend">Current</span>
            </div>
            <div>
                <div class="metric-card__label">Balance</div>
                <div class="metric-card__value">$1,400</div>
            </div>
        </article>

        <article class="metric-card">
            <div class="metric-card__top">
                <span class="metric-card__icon metric-card__icon--savings">S</span>
                <span class="metric-card__trend metric-card__trend--good">+15%</span>
            </div>
            <div>
                <div class="metric-card__label">Savings</div>
                <div class="metric-card__value">$1,400</div>
            </div>
        </article>
    </div>

    <div class="overview-grid">
        <section class="panel">
            <div class="panel__header">
                <div>
                    <h2>Income vs Expenses</h2>
                    <p>Six-month trend of incoming cash versus spending.</p>
                </div>
                <div class="panel__legend">
                    <span style="color:#14b8a6;">Income</span>
                    <span style="color:#4f46e5;">Expenses</span>
                    <span style="color:#9aa8f5;">Savings</span>
                </div>
            </div>

            <svg class="line-chart" viewBox="0 0 920 360" role="img" aria-label="Income and expenses over six months">
                <rect x="0" y="0" width="920" height="360" fill="#fff" />
                <g stroke="#e7eaf2" stroke-width="1">
                    <line x1="70" y1="40" x2="880" y2="40" />
                    <line x1="70" y1="100" x2="880" y2="100" />
                    <line x1="70" y1="160" x2="880" y2="160" />
                    <line x1="70" y1="220" x2="880" y2="220" />
                    <line x1="70" y1="280" x2="880" y2="280" />
                    <line x1="70" y1="320" x2="880" y2="320" />
                </g>
                <g stroke="#dfe3ee" stroke-width="1">
                    <line x1="70" y1="40" x2="70" y2="320" />
                    <line x1="232" y1="40" x2="232" y2="320" />
                    <line x1="394" y1="40" x2="394" y2="320" />
                    <line x1="556" y1="40" x2="556" y2="320" />
                    <line x1="718" y1="40" x2="718" y2="320" />
                    <line x1="880" y1="40" x2="880" y2="320" />
                </g>

                <polyline fill="rgba(79,70,229,0.12)" stroke="none" points="70,188 232,172 394,184 556,146 718,154 880,132 880,320 70,320" />
                <polyline fill="none" stroke="#14b8a6" stroke-width="3.5" points="70,170 232,165 394,172 556,148 718,156 880,130" />
                <polyline fill="none" stroke="#4f46e5" stroke-width="3.5" points="70,188 232,172 394,184 556,146 718,154 880,132" />
                <polyline fill="none" stroke="#9aa8f5" stroke-width="3.5" points="70,228 232,224 394,234 556,198 718,202 880,176" />

                <g fill="#4f46e5">
                    <circle cx="70" cy="188" r="5" />
                    <circle cx="232" cy="172" r="5" />
                    <circle cx="394" cy="184" r="5" />
                    <circle cx="556" cy="146" r="5" />
                    <circle cx="718" cy="154" r="5" />
                    <circle cx="880" cy="132" r="5" />
                </g>

                <g fill="#8b96ad" font-size="14" font-family="Nunito, Segoe UI, sans-serif">
                    <text x="60" y="325">0</text>
                    <text x="42" y="285">1500</text>
                    <text x="42" y="225">3000</text>
                    <text x="42" y="165">4500</text>
                    <text x="42" y="45">6000</text>
                    <text x="60" y="345">Jan</text>
                    <text x="222" y="345">Feb</text>
                    <text x="384" y="345">Mar</text>
                    <text x="546" y="345">Apr</text>
                    <text x="708" y="345">May</text>
                    <text x="870" y="345">Jun</text>
                </g>
            </svg>
        </section>

        <section class="panel">
            <div class="panel__header">
                <div>
                    <h2>Spending by Category</h2>
                    <p>Largest cost centers this month.</p>
                </div>
            </div>

            <div class="donut-wrap">
                <svg class="donut-chart" viewBox="0 0 220 220" role="img" aria-label="Spending by category">
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#eef1f7" stroke-width="28" />
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#4f46e5" stroke-width="28" stroke-linecap="round" stroke-dasharray="102 325" stroke-dashoffset="0" transform="rotate(-90 110 110)" />
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#14b8a6" stroke-width="28" stroke-linecap="round" stroke-dasharray="52 375" stroke-dashoffset="-112" transform="rotate(-90 110 110)" />
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#9aa8f5" stroke-width="28" stroke-linecap="round" stroke-dasharray="84 343" stroke-dashoffset="-172" transform="rotate(-90 110 110)" />
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#f4a300" stroke-width="28" stroke-linecap="round" stroke-dasharray="44 383" stroke-dashoffset="-266" transform="rotate(-90 110 110)" />
                    <circle cx="110" cy="110" r="68" fill="none" stroke="#ea4c89" stroke-width="28" stroke-linecap="round" stroke-dasharray="36 391" stroke-dashoffset="-318" transform="rotate(-90 110 110)" />
                    <circle cx="110" cy="110" r="42" fill="#fff" />
                </svg>

                <div class="donut-meta">
                    <div class="donut-row">
                        <span class="donut-row__swatch" style="background:#4f46e5;"></span>
                        <span>Food &amp; Dining</span>
                        <strong>$850</strong>
                    </div>
                    <div class="donut-row">
                        <span class="donut-row__swatch" style="background:#14b8a6;"></span>
                        <span>Transportation</span>
                        <strong>$420</strong>
                    </div>
                    <div class="donut-row">
                        <span class="donut-row__swatch" style="background:#9aa8f5;"></span>
                        <span>Shopping</span>
                        <strong>$680</strong>
                    </div>
                    <div class="donut-row">
                        <span class="donut-row__swatch" style="background:#f4a300;"></span>
                        <span>Utilities</span>
                        <strong>$380</strong>
                    </div>
                    <div class="donut-row">
                        <span class="donut-row__swatch" style="background:#ea4c89;"></span>
                        <span>Entertainment</span>
                        <strong>$270</strong>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <section class="panel list-panel">
        <div class="list-panel__header">
            <h2>Recent Transactions</h2>
        </div>
        <div class="transaction-list">
            <article class="transaction-item">
                <div class="transaction-item__icon">C</div>
                <div>
                    <div class="transaction-item__title">Grocery Store</div>
                    <div class="transaction-item__meta">Food &amp; Dining</div>
                </div>
                <div class="transaction-item__amount">
                    $85.50
                    <div class="transaction-item__when">Today</div>
                </div>
            </article>
            <article class="transaction-item">
                <div class="transaction-item__icon transaction-item__icon--income">I</div>
                <div>
                    <div class="transaction-item__title">Salary Deposit</div>
                    <div class="transaction-item__meta">Income</div>
                </div>
                <div class="transaction-item__amount transaction-item__amount--positive">
                    +$5000.00
                    <div class="transaction-item__when">Yesterday</div>
                </div>
            </article>
            <article class="transaction-item">
                <div class="transaction-item__icon">U</div>
                <div>
                    <div class="transaction-item__title">Electric Bill</div>
                    <div class="transaction-item__meta">Utilities</div>
                </div>
                <div class="transaction-item__amount">
                    $120.00
                    <div class="transaction-item__when">2 days ago</div>
                </div>
            </article>
            <article class="transaction-item">
                <div class="transaction-item__icon">T</div>
                <div>
                    <div class="transaction-item__title">Gas Station</div>
                    <div class="transaction-item__meta">Transportation</div>
                </div>
                <div class="transaction-item__amount">
                    $45.00
                    <div class="transaction-item__when">3 days ago</div>
                </div>
            </article>
            <article class="transaction-item">
                <div class="transaction-item__icon">F</div>
                <div>
                    <div class="transaction-item__title">Restaurant</div>
                    <div class="transaction-item__meta">Food &amp; Dining</div>
                </div>
                <div class="transaction-item__amount">
                    $68.00
                    <div class="transaction-item__when">3 days ago</div>
                </div>
            </article>
        </div>
    </section>
</section>
