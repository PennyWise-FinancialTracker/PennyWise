@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="privacy-card">
    <h1>@ViewData["Title"]</h1>
    <p>
        PennyWise is currently a classroom project prototype. The app does not persist real user financial data yet,
        and the dashboard content shown in this build is demonstration data used for UI development.
    </p>
    <p>
        When authentication and storage are added, this page should be expanded to document data handling,
        retention, and account deletion policies.
    </p>
</section>
