@{
    var currentPage = ViewContext.ActionDescriptor.RouteValues["page"] ?? string.Empty;
    var isAuthPage = currentPage.StartsWith("/Auth", StringComparison.OrdinalIgnoreCase);
    var isDashboardPage = !isAuthPage &&
        !string.Equals(currentPage, "/Privacy", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(currentPage, "/Error", StringComparison.OrdinalIgnoreCase);

    string NavState(string page) =>
        string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase) ? "app-nav__link is-active" : "app-nav__link";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PennyWise</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PennyWise.styles.css" asp-append-version="true" />
</head>
<body class="@(isDashboardPage ? "dashboard-body" : "auth-body")">
    <header class="app-header">
        <nav class="app-shell">
            <a class="app-brand" asp-page="/Dashboard/Overview">
                <span class="app-brand__mark">$</span>
                <span class="app-brand__text">PennyWise</span>
            </a>

            @if (isDashboardPage)
            {
                <div class="app-shell__menu">
                    <a class="@NavState("/Dashboard/Overview")" asp-page="/Dashboard/Overview">Overview</a>
                    <a class="@NavState("/Dashboard/Transactions")" asp-page="/Dashboard/Transactions">Transactions</a>
                    <a class="@NavState("/Dashboard/Budgets")" asp-page="/Dashboard/Budgets">Budgets</a>
                    <a class="@NavState("/Dashboard/Analytics")" asp-page="/Dashboard/Analytics">Analytics</a>
                </div>

                <div class="app-shell__actions">
                    <a class="app-nav__link" asp-page="/Auth/Login">Logout</a>
                </div>
            }
            else
            {
                <div class="app-shell__menu app-shell__menu--auth">
                    <a class="@NavState("/Auth/Login")" asp-page="/Auth/Login">Login</a>
                    <a class="@NavState("/Auth/Signup")" asp-page="/Auth/Signup">Sign up</a>
                    <a class="@NavState("/Privacy")" asp-page="/Privacy">Privacy</a>
                </div>
            }
        </nav>
    </header>

    <main class="page-shell @(isDashboardPage ? "page-shell--dashboard" : "page-shell--auth")" role="main">
        @RenderBody()
    </main>

    @if (!isDashboardPage)
    {
        <footer class="app-footer">
            <div class="app-footer__inner">
                <span>&copy; 2026 PennyWise</span>
                <a asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
